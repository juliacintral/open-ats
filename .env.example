# ================================
# open-ats — Environment Variables
# ================================
# Copy this file to .env and fill in your values

# ----- DATABASE -----
# Local Docker (default)
DATABASE_URL="postgresql://openats:openats@localhost:5432/openats"

# Neon Free Tier (cloud)
# DATABASE_URL="postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/openats?sslmode=require"

# Supabase Free Tier (cloud)
# DATABASE_URL="postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres"

# ----- REDIS -----
REDIS_URL="redis://localhost:6379"

# ----- JWT AUTH -----
JWT_SECRET="change-me-in-production-use-a-long-random-string"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="change-me-refresh-also-long-random"
JWT_REFRESH_EXPIRES_IN="7d"

# ----- BCRYPT -----
BCRYPT_ROUNDS=12

# ----- AI PROVIDER -----
# Options: ollama | openrouter | localai
AI_PROVIDER="ollama"

# Ollama (local)
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="llama3"
# Alternative models: qwen3, mistral, deepseek-r1, phi3

# OpenRouter (free models fallback)
OPENROUTER_API_KEY=""
OPENROUTER_MODEL="meta-llama/llama-3-8b-instruct:free"

# ----- STORAGE -----
# Options: supabase | minio | local
STORAGE_PROVIDER="local"
STORAGE_LOCAL_PATH="./uploads"

# Supabase Storage
SUPABASE_URL=""
SUPABASE_ANON_KEY=""
SUPABASE_BUCKET="resumes"

# MinIO (self-hosted S3-compatible)
MINIO_ENDPOINT="localhost"
MINIO_PORT=9000
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin"
MINIO_BUCKET="resumes"
MINIO_USE_SSL=false

# ----- EMAIL -----
# Options: smtp | brevo
EMAIL_PROVIDER="smtp"
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="noreply@openats.local"

# Brevo (free 300 emails/day)
BREVO_API_KEY=""

# ----- CALENDAR -----
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
MICROSOFT_CLIENT_ID=""
MICROSOFT_CLIENT_SECRET=""

# ----- APP -----
NODE_ENV="development"
APP_PORT=3333
FRONTEND_URL="http://localhost:3000"
CORS_ORIGINS="http://localhost:3000"

# ----- SEARCH -----
# Options: postgres | meilisearch
SEARCH_PROVIDER="postgres"
MEILISEARCH_URL="http://localhost:7700"
MEILISEARCH_API_KEY=""
